# Invoicing & Billing blueprint — production integration knobs.
# Copy to .env and fill in for a real deployment. The demo runs WITHOUT any of these.

# --- Billing terms (swap into src/config.py BillingConfig) ---
TAX_RATE=0.08                         # fraction, e.g. 0.08 = 8%
PAYMENT_TERMS_DAYS=30                 # net terms: due = period end + N days
REMINDER_OFFSETS_DAYS=3,7,14          # escalating reminders, days past due
CURRENCY=USD

# --- Invoicing / billing system (swap into src/ledger.py _write) ---
BILLING_PROVIDER=stripe               # stripe | quickbooks | xero
STRIPE_API_KEY=
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REALM_ID=

# --- Usage / metering source (feeds src/pipeline.py aggregate_usage) ---
USAGE_SOURCE=stripe_meter             # stripe_meter | bigquery | csv
USAGE_API_KEY=

# --- Email delivery (invoices + reminders) ---
EMAIL_PROVIDER=postmark               # postmark | sendgrid | ses
EMAIL_API_KEY=
FROM_EMAIL=billing@example.com
REPLY_TO_EMAIL=ar@example.com

# --- Optional: LLM-drafted dunning copy (swap into a reminder formatter) ---
# Default model when building AI features here: claude-opus-4-8
ANTHROPIC_API_KEY=
REMINDER_MODEL=claude-opus-4-8
