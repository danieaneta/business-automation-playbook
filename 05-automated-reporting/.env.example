# Automated Reporting blueprint — production integration knobs.
# Copy to .env and fill in for a real deployment. The demo runs WITHOUT any of these.

# --- CRM source (swap into src/connectors.py _read for source 'crm') ---
CRM_PROVIDER=hubspot                  # hubspot | salesforce | pipedrive
CRM_API_KEY=
CRM_BASE_URL=

# --- Billing source (swap into src/connectors.py _read for source 'billing') ---
BILLING_PROVIDER=stripe               # stripe | chargebee | recurly
STRIPE_API_KEY=
BILLING_API_KEY=

# --- Analytics source (swap into src/connectors.py _read for source 'analytics') ---
ANALYTICS_PROVIDER=ga4                # ga4 | plausible | mixpanel
ANALYTICS_API_KEY=
GA4_PROPERTY_ID=

# --- Report tuning (swap into src/config.py ReportConfig) ---
HIGHLIGHT_THRESHOLD_PCT=10            # flag a metric when |pct change| >= this

# --- Optional: LLM narrative summary (swap into src/digest.py) ---
# Default model when building AI features here: claude-opus-4-8
ANTHROPIC_API_KEY=
SUMMARY_MODEL=claude-opus-4-8

# --- Delivery (swap into src/delivery.py _send) ---
DELIVERY_CHANNEL=slack                # slack | email
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#weekly-metrics
REPORT_EMAIL_TO=leadership@example.com
