# Lead → CRM blueprint — production integration knobs.
# Copy to .env and fill in for a real deployment. The demo runs WITHOUT any of these.

# --- Enrichment provider (swap into src/enrichment.py) ---
ENRICHMENT_PROVIDER=apollo            # apollo | clearbit | none
APOLLO_API_KEY=
CLEARBIT_API_KEY=

# --- CRM (swap into src/crm_client.py _write) ---
CRM_PROVIDER=hubspot                  # hubspot | pipedrive | gohighlevel
CRM_API_KEY=
CRM_BASE_URL=

# --- Optional: LLM scoring (swap into src/scoring.py) ---
# Default model when building AI features here: claude-opus-4-8
ANTHROPIC_API_KEY=
SCORING_MODEL=claude-opus-4-8

# --- Follow-up dispatch (hot leads) ---
SLACK_WEBHOOK_URL=
NOTIFY_SALES_EMAIL=sales@example.com
