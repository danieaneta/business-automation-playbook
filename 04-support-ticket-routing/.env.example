# Support ticket routing blueprint — production integration knobs.
# Copy to .env and fill in for a real deployment. The demo runs WITHOUT any of these.

# --- Inbound source (helpdesk / inbox that fires the workflow) ---
HELPDESK_PROVIDER=zendesk             # zendesk | freshdesk | intercom | imap
HELPDESK_API_KEY=
HELPDESK_BASE_URL=
INBOUND_INBOX=support@example.com

# --- Ticket store / helpdesk write-back (swap into src/ticket_store.py _write) ---
TICKET_STORE_PROVIDER=zendesk         # zendesk | freshdesk | intercom
TICKET_STORE_API_KEY=

# --- Optional: LLM classifier (swap into src/classifier.py classify) ---
# Default model when building AI features here: claude-opus-4-8
ANTHROPIC_API_KEY=
CLASSIFIER_MODEL=claude-opus-4-8

# --- Routing / escalation dispatch ---
SLACK_WEBHOOK_URL=
ONCALL_PAGER_URL=                     # PagerDuty/Opsgenie webhook for high-priority pages
ONCALL_SLACK_CHANNEL=oncall-alerts
