# Client onboarding blueprint — production integration knobs.
# Copy to .env and fill in for a real deployment. The demo runs WITHOUT any of these.

# --- CRM trigger (deal marked "Won") ---
CRM_PROVIDER=hubspot                  # hubspot | pipedrive | salesforce
CRM_API_KEY=
CRM_WON_STAGE=closedwon               # deal stage that fires onboarding

# --- Provisioning: account + workspace (swap into src/provisioning_client._run_step) ---
PROVISIONING_PROVIDER=auth0           # auth0 | workos | cognito
PROVISIONING_API_KEY=
WORKSPACE_API_URL=

# --- Billing (add_to_billing step) ---
BILLING_PROVIDER=stripe               # stripe | chargebee | recurly
STRIPE_API_KEY=
STRIPE_DEFAULT_PRICE_ID=

# --- Welcome email (send_welcome_email step) ---
EMAIL_PROVIDER=postmark               # postmark | sendgrid | ses
EMAIL_API_KEY=
FROM_EMAIL=success@example.com

# --- Kickoff scheduling (schedule_kickoff step) ---
SCHEDULER_PROVIDER=calendly           # calendly | google_calendar
SCHEDULER_API_KEY=
KICKOFF_EVENT_TYPE=onboarding-kickoff

# --- Optional: LLM checklist tailoring (swap into src/engine.required_steps) ---
# Default model when building AI features here: claude-opus-4-8
ANTHROPIC_API_KEY=
ONBOARDING_MODEL=claude-opus-4-8

# --- SLA / ops ---
ONBOARDING_SLA_HOURS=48
CSM_NOTIFY_CHANNEL=onboarding-enterprise   # Slack channel for assign_csm (enterprise)
